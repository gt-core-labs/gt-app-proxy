 # Copy to .env and adjust. docker compose reads .env automatically.

# --- Compose project ---
# Pin the project name to `gt-app` so this proxy deploy REUSES the original gt-app stack's
# named volumes (gt-app_dolt-data / gt-app_gt-pgdata / gt-app_gt-eventlog / gt-app_minio-data)
# instead of creating empty `gt-app-proxy_*` ones. The cutover then preserves all data.
COMPOSE_PROJECT_NAME=gt-app

# --- Dolt (issues/meta tracking) ---
# MySQL-wire user created on first boot; passwordless on the internal network.
DOLT_USER=gtapp

# --- Postgres credentials (durable audit + dispatch domains) ---
POSTGRES_USER=gtapp
POSTGRES_PASSWORD=gtapp
POSTGRES_DB=gtapp

# --- MinIO (object store for binary document attachments, docs/11) ---
# Root credentials; the server's blob client (GT_BLOB_ACCESS/SECRET) reuses them.
MINIO_ROOT_USER=gtapp
MINIO_ROOT_PASSWORD=gtappsecret
# Host port the MinIO operator console is published on (loopback only).
MINIO_CONSOLE_PORT=9001
# Bucket the document subsystem stores blobs in (created on first boot).
GT_BLOB_BUCKET=gt-documents
# S3 region label (MinIO ignores it, but the S3 client requires one).
GT_BLOB_REGION=us-east-1

# --- gt-mcp-server ---
# Host port the MCP server is published on (loopback only).
GT_MCP_PORT=8765
# Default actor resolved against the scope profile. `mcp-local` = the dev profile's full actor.
GT_MCP_ACTOR=mcp-local
# RBAC scope profile shipped in core: dev (full) | readonly (*.validate only) | closed (deny).
# Tighten before any multi-client / production exposure. For a bespoke policy, leave this and
# instead point GT_MCP_SCOPE_CONFIG at a mounted file (it takes precedence).
GT_MCP_SCOPE_PROFILE=dev
# Log level: error | warn | info | debug | trace
RUST_LOG=info

# --- Public reverse-proxy deploy (gt-app-proxy) ---
# Domain Traefik routes to this backend over HTTPS (ACME DNS-01 via the plane proxy's netlify
# resolver). Also goes into GT_MCP_ALLOWED_HOSTS so the /mcp transport accepts the proxied Host.
GT_DOMAIN=gt.codecsrayo.com
GT_MCP_ALLOWED_HOSTS=gt.codecsrayo.com,gt.codecsrayo.com:443
# Signing key id stamped on minted access JWTs; must match the verifier keyset entry.
GT_JWT_RS256_SIGNING_KID=gt-main

# --- Traefik (the `proxy` service, owned by this repo) ---
# ACME DNS-01 via Netlify: the token authorizes the TXT challenge, the email registers the ACME
# account. ACME state (issued certs) persists in secrets/acme.json (gitignored) — seed it from an
# existing proxy's acme.json to avoid re-minting and Let's Encrypt rate limits.
NETLIFY_TOKEN=nfp_xxx
TRAEFIK_ACME_EMAIL=you@example.com
# Access/refresh token lifetimes (seconds): 15m access, 30d refresh.
GT_AUTH_ACCESS_TTL_SECS=900
GT_AUTH_REFRESH_TTL_SECS=2592000

# --- Admin seed (hq-web-extras.7) ---
# On boot the backend upserts this admin into ws_default.users (argon2, scopes ["*"]). Both must
# be set or the seed is skipped. No insecure default for the password — choose a strong one.
GT_ADMIN_EMAIL=admin@gt.local
GT_ADMIN_PASSWORD=change-me-strong

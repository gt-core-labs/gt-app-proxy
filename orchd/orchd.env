# gt-orch-server env — hq-orchd-deploy. Daemon is OFF by default (run.sh is manual; the GO is .5).
# Shared event-log volume (bead .3): host path of the docker volume gt-app_gt-eventlog,
# the SAME log the containerized gt-mcp-server mounts at /var/lib/gt-core.
# NOTE: this path is root-owned -> the daemon must run as root (or a uid with access).
GT_EVENTLOG_ROOT=/var/lib/docker/volumes/gt-app_gt-eventlog/_data
GT_WORKSPACE=default

# Cost gate (bead .5): start minimal. 1 slot, conservative RAM, host cap from CPU+RAM.
GT_POOL_SIZE=1
GT_POLECAT_MEM_MB=1024
GT_POLECAT_TICK_SECS=15
GT_POLECAT_MAX_RESTARTS=64

# Metrics scrape (separate process from mcp-server's /metrics).
GT_METRICS_BIND=127.0.0.1:9099

# Reactor tickers (incl. the predictive quota ticker, ap.7).
GT_PATROL_TICK_SECS=30
GT_LEASE_TIMEOUT_SECS=300
GT_QUOTA_TICK_SECS=60
GT_QUOTA_THRESHOLD_SECS=300

# gt-channel mailboxes (all under the shared eventlog volume so container + host agree).
GT_CHANNEL_ROOT=/var/lib/docker/volumes/gt-app_gt-eventlog/_data/.channels
GT_MERGE_READY_CHANNEL=merge-ready
GT_DISPATCH_CHANNEL=dispatch
# ap.7 INPUT: drop {"account","headers"|"sample"} JSON here to feed the predictor (rotate before limit).
GT_QUOTA_FEED_CHANNEL=quota-feed

# --- Polecat executor (beads .2/.7/.9) ---
GT_RIG=hq
GT_POLECAT_PREFIX=gt
GT_POLECAT_CMD=claude
# Base rig checkout the per-polecat worktrees branch FROM (must exist; clone of gt-core on main).
GT_RIG_PATH=/home/nixos/gt-rig-hq
# deploy.9: each polecat gets its OWN git worktree under this root (branch = bead) off GT_RIG_PATH,
# so concurrent polecats never race on a shared HEAD. Unset => single shared checkout (1 polecat only).
GT_POLECAT_WORKTREE_ROOT=/home/nixos/gt-rig-hq-wt
# ap.1/.2/.7: the heartbeat dir the polecat hooks touch (staleness => re-sling).
GT_HEARTBEAT_DIR=/var/lib/docker/volumes/gt-app_gt-eventlog/_data/.heartbeats

# --- Security: drop polecat privileges (hq-quota-accounts.6) ---
# The daemon runs as root (needs the root-owned eventlog volume) but a polecat must NOT: it carries
# --dangerously-skip-permissions + its account's claude creds, so a root session could read OTHER
# accounts' creds, the RS256 key, and the whole volume. GT_POLECAT_RUN_AS re-execs the polecat as a
# dedicated non-root user (via runuser) and chowns its worktree to it. Unset => runs as root (legacy).
# HOST SETUP when enabling: `useradd -r -m gtpolecat`; make GT_POLECAT_WORKTREE_ROOT, the account
# dirs (GT_CLAUDE_ACCOUNTS_ROOT), GT_HEARTBEAT_DIR and the dispatch/merge-ready/quota-feed channels
# readable+writable by gtpolecat; keep GT_JWT_RS256_PRIVATE_KEY_FILE root-only (0600).
# GT_POLECAT_RUN_AS=gtpolecat

# Where per-account CLAUDE_CONFIG_DIRs live (hq-quota-accounts.3); default <GT_EVENTLOG_ROOT>/accounts.
# GT_CLAUDE_ACCOUNTS_ROOT=/var/lib/docker/volumes/gt-app_gt-eventlog/_data/accounts

# --- Per-agent identity (ap.3) ---
# RS256 private key the daemon signs each polecat's least-privilege GT_TOKEN with. Unset => polecats
# sling WITHOUT a token (they cannot drive the gt MCP tracker). MUST be set for the GO.
# GT_JWT_RS256_PRIVATE_KEY_FILE=/home/nixos/gt-app-proxy/orchd/jwt_private.pem
GT_AGENT_TOKEN_TTL_SECS=3600

# --- Claude accounts for predictive rotation (ap.7) — OPERATOR MUST FILL with real values ---
# Comma list of account=CLAUDE_CONFIG_DIR pairs; first is boot-active. >=2 enables rotation BEFORE
# the limit. Unset/single => single-account mode (hits the session limit on a long run). Each dir is
# a CLAUDE_CONFIG_DIR holding that account's logged-in claude creds.
# GT_CLAUDE_ACCOUNTS=acctA=/home/nixos/.claude-acctA,acctB=/home/nixos/.claude-acctB

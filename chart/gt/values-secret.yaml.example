# Example secret override for `helm install -f values-secret.yaml`.
# Copy to values-secret.yaml (gitignored) and fill in the real values, OR use a
# sealed-secrets / external-secrets workflow with secrets.create=false.
#
# NEVER commit the filled-in file. Mirrors the compose .env + ./secrets/* files.
secrets:
  create: true
  # DB / object store credentials.
  postgresPassword: "CHANGE-ME"
  minioRootUser: gtapp
  minioRootPassword: "CHANGE-ME"
  # OAuth at-rest sealing key (required for oauth-feature image builds).
  secretKey: "CHANGE-ME-32-byte-base64-or-hex"
  oidcRedirectUri: "https://gt.codecsrayo.com/auth/callback"
  oauthFeRedirectUrl: ""
  # Cleartext client_secret for the boot-seeded `google` OAuth provider. Empty ⇒
  # the google login button is skipped at boot. The seeded provider is enabled=false
  # until an admin enables it in /admin/providers.
  oauthSeedSecretGoogle: ""   # GT_OAUTH_SEED_SECRET_GOOGLE
  # Admin seed (both required or the binary skips the seed).
  adminEmail: "admin@gt.local"
  adminPassword: "CHANGE-ME-strong"
  # RS256 login keys — paste the PEM bodies (the ./secrets/jwt_*.pem contents).
  jwtPrivateKey: |
    -----BEGIN PRIVATE KEY-----
    ...
    -----END PRIVATE KEY-----
  jwtPublicKey: |
    -----BEGIN PUBLIC KEY-----
    ...
    -----END PUBLIC KEY-----
  # GitHub App (push webhook + private-rig JIT tokens). Leave empty to disable.
  githubAppId: ""
  githubAppPrivateKey: ""
  githubAppWebhookSecret: ""
  # Rig clone token for the orchd singleton (private repo).
  rigGitToken: ""
